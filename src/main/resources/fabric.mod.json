{
	"schemaVersion": 1,
	"id": "street_art",
	"version": "${version}",
	"name": "Street Art",
	"description": "An art mod for cool delinquents, allowing you to spray paint any block",
	"authors": [
		"BeeIsYou",
		"Cyvack",
		"MasonMaddy"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "MIT",
	"icon": "assets/street_art/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.streetart.StreetArt"
		],
		"client": [
			"com.streetart.client.StreetArtClient"
		],
		"fabric-datagen": [
			"com.streetart.client.StreetArtDataGenerator"
		]
	},
	"mixins": [
		"street_art.mixins.json",
		{
			"config": "street_art.client.mixins.json",
			"environment": "client"
		}
	],
	"accessWidener": "street_art.classtweaker",
	"depends": {
		"fabricloader": ">=0.18.6",
		"minecraft": "~26.1.1",
		"java": ">=25",
		"fabric-api": "*",
		"yet_another_config_lib_v3": ">=3.9.3"
	},
	"suggests": {
		"area_lib": ">=0.8.0",
		"slime_time": "*"
	}
}